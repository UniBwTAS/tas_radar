<?xml version="1.0"?>
<package format="3">
  <name>smartmicro_configurator</name>
  <version>2.1.0</version>
  <description>Smartmicro Systems (SMS) configuration tool for sensors based on the "High Performance Sensors Firmware"</description>
  <author>Philipp Berthold</author>
  <maintainer email="philipp.berthold@unibw.de">phbe</maintainer>
  <license>BSD</license>

  <!-- ROS 1 only: Qt5 + librosqt GUI tool -->
  <buildtool_depend condition="$ROS_VERSION == 1">catkin</buildtool_depend>
  <build_depend condition="$ROS_VERSION == 1">message_generation</build_depend>
  <depend condition="$ROS_VERSION == 1">roscpp</depend>
  <depend condition="$ROS_VERSION == 1">std_msgs</depend>
  <depend condition="$ROS_VERSION == 1">smartmicro_driver</depend>
  <depend condition="$ROS_VERSION == 1">radar_msgs</depend>
  <depend condition="$ROS_VERSION == 1">can_msgs</depend>
  <depend condition="$ROS_VERSION == 1">librosqt</depend>

  <!-- ROS 2: package is present but builds nothing (ROS 1-only tool) -->
  <buildtool_depend condition="$ROS_VERSION == 2">ament_cmake</buildtool_depend>

</package>
